# Deployer private key — set this to sign deployment txs
# Hardhat reads DEPLOYER_PRIVATE_KEY from this file automatically
# DEPLOYER_PRIVATE_KEY=0x...

# Robinhood Chain Testnet RPC (optional, defaults to public endpoint)
# ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Arbitrum Sepolia RPC (optional, defaults to public endpoint)
# ARBITRUM_RPC_URL=https://sepolia-sequencer.arbitrum.io/rpc
